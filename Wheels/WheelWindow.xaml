<Window x:Class="Spinix.Wheels.WheelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wheels="clr-namespace:Spinix.Wheels"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        RenderOptions.ClearTypeHint="Auto"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Grid>
        <Grid.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.4" Color="Black"/>
        </Grid.Effect>
        <wheels:WheelControl x:Name="Wheel" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
